+          currency:
+            typeof req.body.currency === "string"
+              ? req.body.currency
+              : undefined,
+          notes:
+            typeof req.body.notes === "string" ? req.body.notes : undefined,
+        },
+        req.user!,
+      ),
+    );
+  }),
