NODE_ENV=development

PORT=4000
API_PREFIX=/api/v1

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Points to the local mongo service defined in docker-compose.yml
MONGODB_URI=mongodb://mongo:27017/aidn

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Paths are resolved relative to the api package root (/app inside the container)
JWT_PRIVATE_KEY_BASE64=./src/shared/certs/jwt-private.b64
JWT_PUBLIC_KEY_BASE64=./src/shared/certs/jwt-public.b64
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Cookies & CSRF ──────────────────────────────────────────────────────────
AUTH_COOKIE_NAME=aidn_admin_session
PORTAL_AUTH_COOKIE_NAME=aidn_portal_session
AUTH_CSRF_COOKIE_NAME=aidn_admin_csrf
PORTAL_CSRF_COOKIE_NAME=aidn_portal_csrf
CSRF_HEADER_NAME=x-csrf-token
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# ─── Rate limiting & upload ───────────────────────────────────────────────────
PUBLIC_ACCOUNT_REQUEST_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_ACCOUNT_REQUEST_RATE_LIMIT_MAX=5
PUBLIC_ACCOUNT_REQUEST_MIN_SUBMIT_MS=3000
UPLOAD_STORAGE_DIR=./storage
PORTAL_REQUEST_COURRIER_MAX_FILE_SIZE_MB=10

# ─── Bootstrap admin ─────────────────────────────────────────────────────────
BOOTSTRAP_ADMIN_FULL_NAME=Bootstrap Admin
BOOTSTRAP_ADMIN_EMAIL=admin@aidn.local
BOOTSTRAP_ADMIN_PASSWORD=password

# ─── Personnel DB ────────────────────────────────────────────────────────────
# Disabled in docker dev — no local MySQL; mock data is used instead
OFFICIAL_PERSONNEL_DB_ENABLED=true
MOCK_PERSONNEL_ENABLED=true
OFFICIAL_PERSONNEL_DB_HOST=100.98.64.49
OFFICIAL_PERSONNEL_DB_PORT=3307
OFFICIAL_PERSONNEL_DB_NAME=dev_db
OFFICIAL_PERSONNEL_DB_USER=admin
OFFICIAL_PERSONNEL_DB_PASSWORD=admin

# ─── Dev flags ───────────────────────────────────────────────────────────────
ALLOW_DEV_DATA_RESET=true
